<Page
    x:Class="TournamentAppProject.MatchesListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TournamentAppProject"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel HorizontalAlignment="Center"
                    Margin="10,10,10,10">
            <TextBlock x:ConnectionId='1' Name="TournamentIdTextBlock"
                       Visibility="Collapsed"/>
            <TextBlock x:ConnectionId='2' Name="TournamentNameTextBlock"
                           FontSize="26" />
            <ProgressRing x:ConnectionId='3' Name="MyProgressRing" Height="45" Width="45"/>
            <ListView x:ConnectionId='4' Name="MatchesListListView"
                                                                             
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding TeamOneScore}" />
                            <TextBlock Text="{Binding TeamOneName}"
                                       Margin="10,0,0,0" />
                            <TextBlock Text=" vs." 
                                       Margin="10,0,0,0"  />
                            <TextBlock Text="{Binding TeamTwoName}"
                                       Margin="10,0,0,0" />
                            <TextBlock Text="{Binding TeamTwoScore}"
                                       Margin="10,0,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>

